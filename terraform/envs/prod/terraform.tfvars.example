aws_region = "ap-northeast-2"
name_prefix = "devsecops-prod"
vpc_cidr = "10.20.0.0/16"
azs = ["ap-northeast-2a", "ap-northeast-2c"]
public_subnet_cidrs = ["10.20.1.0/24", "10.20.2.0/24"]
private_subnet_cidrs = ["10.20.11.0/24", "10.20.12.0/24"]

ecr_repositories = [
  "api-node",
  "api-python",
  "api-spring",
  "controlplane-api",
  "frontend"
]

services = {
  frontend = {
    cpu            = 512
    memory         = 1024
    container_port = 80
    desired_count  = 2
    image          = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/devsecops-prod/frontend:latest"
    environment    = {}
    priority       = 100
    path_patterns  = ["/*"]
    health_check   = "/"
  }
  api-node = {
    cpu            = 512
    memory         = 1024
    container_port = 3000
    desired_count  = 2
    image          = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/devsecops-prod/api-node:latest"
    environment    = {
      NODE_ENV = "production"
      PORT     = "3000"
    }
    priority       = 10
    path_patterns  = ["/node*", "/api/node*"]
    health_check   = "/health"
  }
  api-python = {
    cpu            = 512
    memory         = 1024
    container_port = 8000
    desired_count  = 2
    image          = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/devsecops-prod/api-python:latest"
    environment    = {
      APP_ENV = "production"
      PORT    = "8000"
    }
    priority       = 20
    path_patterns  = ["/python*", "/api/python*"]
    health_check   = "/health"
  }
  api-spring = {
    cpu            = 1024
    memory         = 2048
    container_port = 8080
    desired_count  = 2
    image          = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/devsecops-prod/api-spring:latest"
    environment    = {
      SPRING_PROFILES_ACTIVE = "prod"
      SERVER_PORT            = "8080"
    }
    priority       = 30
    path_patterns  = ["/spring*", "/api/spring*"]
    health_check   = "/api/health"
  }
  controlplane-api = {
    cpu            = 512
    memory         = 1024
    container_port = 4000
    desired_count  = 1
    image          = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/devsecops-prod/controlplane-api:latest"
    environment    = {
      PORT                = "4000"
      NODE_ENV            = "production"
      API_BASE_PATH       = "/controlplane"
      FRONTEND_ORIGIN     = "https://replace-me.example.com"
      GITHUB_OWNER        = "aws-security-project"
      GITHUB_REPO         = "aws-security-project"
      GITHUB_APP_ID       = "1234567"
      GITHUB_APP_CLIENT_ID = ""
      LLM_MODEL           = "gemini-2.5-flash-lite"
    }
    secrets       = {
      GITHUB_APP_PRIVATE_KEY = "arn:aws:secretsmanager:ap-northeast-2:123456789012:secret:devsecops-prod/controlplane/github-app-private-key"
      GEMINI_API_KEY         = "arn:aws:secretsmanager:ap-northeast-2:123456789012:secret:devsecops-prod/controlplane/gemini-api-key"
    }
    priority      = 40
    path_patterns = ["/controlplane/*"]
    health_check  = "/health"
  }
}

tags = {
  Project     = "my-devsecops-platform"
  Environment = "prod"
  ManagedBy   = "terraform"
}
