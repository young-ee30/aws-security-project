# Local API server port
PORT=4000

# Runtime environment: development | production
NODE_ENV=development

# Allowed frontend origin for CORS
# Use a comma-separated list for multiple origins, or * to allow any origin without credentials.
FRONTEND_ORIGIN=http://localhost:5173

# Optional base path when the API is mounted behind an ALB path rule.
# Example: API_BASE_PATH=/controlplane
API_BASE_PATH=

# Optional Prometheus metrics upstream for the App HTTP dashboard
# Example: METRICS_SOURCE_URL=http://localhost:5000/api/metrics
METRICS_SOURCE_URL=

# GitHub repository target
GITHUB_OWNER=young-ee30
GITHUB_REPO=aws-security-project

# GitHub App settings
GITHUB_APP_ID=1234567
GITHUB_APP_CLIENT_ID=Iv1.0123456789abcdef

# GitHub App private key content or absolute .pem path
# Example:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_PRIVATE_KEY="C:\\Users\\User\\Desktop\\github-app-private-key.pem"
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# LLM settings
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-5.4-mini
