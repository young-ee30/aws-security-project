# 로컬 API 서버 포트
PORT=

# 실행 환경: development | production
NODE_ENV=

# CORS 허용 프론트 주소
# 로컬 대시보드 주소:
FRONTEND_ORIGIN=

# GitHub 저장소 위치
GITHUB_OWNER=
GITHUB_REPO=

# GitHub App 페이지 -> General 에서 확인하는 값
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=

# GitHub App 개인키 (.pem 파일 절대 경로)
GITHUB_APP_PRIVATE_KEY=

# 지금 로컬 MVP는 webhook 대신 polling을 쓰므로 비워둬도 됩니다
GITHUB_WEBHOOK_SECRET=

# LLM 설정
LLM_API_KEY=
LLM_MODEL=

# AWS 설정
AWS_REGION=
NAME_PREFIX=
