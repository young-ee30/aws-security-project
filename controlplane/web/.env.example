# Leave blank in local development to use the Vite proxy to controlplane/api.
# Example for ALB path-based deploy: VITE_API_BASE_URL=https://your-domain.example.com/controlplane
VITE_API_BASE_URL=

# Optional separate metrics source for the App HTTP dashboard.
# Leave blank to use controlplane/api /api/metrics.
VITE_METRICS_URL=
