{
  "name": "ecommerce-api-server",
  "version": "1.0.0",
  "description": "쿠팡 스타일 이커머스 API 서버 - AWS 교육용",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "seed": "node seed.js",
    "prometheus": "docker run --rm -p 127.0.0.1:9090:9090 -v \"./prometheus.yml:/etc/prometheus/prometheus.yml:ro\" prom/prometheus",
    "prometheus:9091": "docker run --rm -p 127.0.0.1:9091:9090 -v \"./prometheus.yml:/etc/prometheus/prometheus.yml:ro\" prom/prometheus",
    "prometheus:local": "prometheus.exe --config.file=prometheus.yml --storage.tsdb.path=.prometheus-data --web.listen-address=127.0.0.1:9090"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.400.0",
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/client-sns": "^3.400.0",
    "@aws-sdk/client-sqs": "^3.400.0",
    "@aws-sdk/lib-dynamodb": "^3.400.0",
    "@aws-sdk/s3-request-presigner": "^3.400.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.7.0",
    "prom-client": "^15.1.3",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.0"
  },
  "keywords": [
    "ecommerce",
    "express",
    "aws",
    "education"
  ],
  "license": "MIT"
}
